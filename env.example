# =================================================================
# KARAM — Environment variables
# Copy this file to .env.local for local dev, OR set these directly
# in the Vercel dashboard under Settings → Environment Variables.
# =================================================================

# --- Admin login ---
# Pick a strong password. This is what you type at /admin to sign in.
ADMIN_PASSWORD=change-me-please

# A random string used to sign admin session tokens. Make it long and
# random. Generate one with:    openssl rand -hex 32
JWT_SECRET=replace-with-a-long-random-hex-string

# --- Telegram (REQUIRED: orders are delivered here) ---
# 1. Message @BotFather on Telegram, /newbot, follow prompts → token.
# 2. Open chat with your new bot, send any message.
# 3. Visit https://api.telegram.org/bot<TOKEN>/getUpdates → find "chat":{"id": ...}
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Stripe (OPTIONAL: leave blank for cash-on-delivery mode) ---
# Get these from https://dashboard.stripe.com/apikeys (use TEST keys first)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# After adding the webhook in the Stripe dashboard (see README),
# Stripe shows you a signing secret starting with whsec_… → paste it here.
STRIPE_WEBHOOK_SECRET=

# --- Site URL (used to build Stripe success/cancel redirects) ---
# Set to your final domain in production, e.g. https://karam.london
PUBLIC_SITE_URL=http://localhost:3000

# --- Vercel KV ---
# These are auto-injected by Vercel when you connect a KV database to
# your project. You don't need to set them manually.
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
